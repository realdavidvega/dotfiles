# yt-dlp aliases with sensible defaults for videos, audio, and playlists.
# Source: ~/.dotfiles/aliases/.youtube-dl-aliases

sourceif "$DOTFILES_PATH/scripts/yt-dlp/yt-dlp-common.sh"

function yt-mp4 {
    local url="${1:?missing URL}"
    shift || true
    local ytdlp
    ytdlp="$(_yt_dlp_cmd)" || return 1
    local -a args=(-f "bestvideo[ext=mp4]+bestaudio[ext=m4a]/mp4" --merge-output-format mp4)
    _yt_dlp_append_args "$(_yt_dlp_video_args)"
    _yt_dlp_append_args "$(_yt_dlp_cookies "$ytdlp")"
    "$ytdlp" "${args[@]}" "$@" -- "$url"
}

function yt-best {
    local url="${1:?missing URL}"
    shift || true
    local ytdlp
    ytdlp="$(_yt_dlp_cmd)" || return 1
    local -a args=(-f "bestvideo+bestaudio")
    _yt_dlp_append_args "$(_yt_dlp_video_args)"
    _yt_dlp_append_args "$(_yt_dlp_cookies "$ytdlp")"
    "$ytdlp" "${args[@]}" "$@" -- "$url"
}

function yt {
    local url="${1:?missing URL}"
    shift || true
    local ytdlp
    ytdlp="$(_yt_dlp_cmd)" || return 1
    local -a args=(-S ext)
    _yt_dlp_append_args "$(_yt_dlp_video_args)"
    _yt_dlp_append_args "$(_yt_dlp_cookies "$ytdlp")"
    "$ytdlp" "${args[@]}" "$@" -- "$url"
}

alias yt-mp4-alt="yt-dlp -f 22"
alias yt-mkv="yt-dlp --recode-video mkv -f 22"
alias ytf="yt-dlp -f"
alias ytlf="yt-dlp --list-formats"

function yta-mp3 {
    if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        printf '%s\n' "Usage: yta-mp3 URL [yt-dlp options]"
        return 0
    fi

    local url="${1:?missing URL}"
    shift || true
    local ytdlp
    ytdlp="$(_yt_dlp_cmd)" || return 1
    local -a args=(--audio-format mp3 --audio-quality 0)
    _yt_dlp_append_args "$(_yt_dlp_audio_args)"
    _yt_dlp_append_args "$(_yt_dlp_cookies "$ytdlp")"
    "$ytdlp" "${args[@]}" "$@" -- "$url"
}

